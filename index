<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Nota Final</title>
    <style>
        *{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f4f4f4;
    padding:40px;
}

h1{
    text-align:center;
    margin-bottom:30px;
}

.container{
    display:flex;
    gap:30px;
    justify-content:center;
    flex-wrap:wrap;
}

.card{
    background:white;
    width:400px;
    padding:25px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,.15);
}

.card h2{
    text-align:center;
    margin-bottom:20px;
    color:#2b5da7;
}

label{
    display:block;
    margin-top:15px;
    font-weight:bold;
}

input{
    width:100%;
    padding:10px;
    margin-top:5px;
    border-radius:8px;
    border:1px solid #bbb;
    font-size:16px;
}

button{
    display:block;
    margin:35px auto;
    padding:15px 40px;
    border:none;
    border-radius:8px;
    background:#2b5da7;
    color:white;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#20487f;
}

#resultado{
    text-align:center;
}

#nota{
    font-size:55px;
    color:green;
    font-weight:bold;
    margin-top:15px;
}
    </style>
</head>
<body>

<h1>Calculadora da Avaliação da Aprendizagem</h1>

<div class="container">

    <div class="card">
        <h2>Avaliação dos Conhecimentos (70%)</h2>

        <label>Prova Objetiva (15%)</label>
        <input type="number" id="objetiva" min="0" max="100">

        <label>Prova Dissertativa (30%)</label>
        <input type="number" id="dissertativa" min="0" max="100">

        <label>UAs / Atividades (10%)</label>
        <input type="number" id="atividades" min="0" max="100">

        <label>Entrega Final (15%)</label>
        <input type="number" id="entrega" min="0" max="100">
    </div>

    <div class="card">
        <h2>Avaliação Formativa (30%)</h2>

        <label>Habilidades Cognitivas (10%)</label>
        <input type="number" id="cognitivas" min="0" max="100">

        <label>Comunicação Oral/Escrita (10%)</label>
        <input type="number" id="comunicacao" min="0" max="100">

        <label>Auto Gestão (2,5%)</label>
        <input type="number" id="autogestao" min="0" max="100">

        <label>Protagonismo (2,5%)</label>
        <input type="number" id="protagonismo" min="0" max="100">

        <label>Autonomia (2,5%)</label>
        <input type="number" id="autonomia" min="0" max="100">

        <label>Interação (2,5%)</label>
        <input type="number" id="interacao" min="0" max="100">
    </div>

</div>

<button onclick="calcular()">Calcular Nota Final</button>

<div id="resultado">
    <h2>Nota Final</h2>
    <p id="nota">0,00</p>
</div>

<script>
    function valor(id){
    let v = parseFloat(document.getElementById(id).value);

    if(isNaN(v))
        return 0;

    return v;
}

function calcular(){

    let notaFinal = 0;

    // Conhecimentos
    notaFinal += valor("objetiva") * 0.15;
    notaFinal += valor("dissertativa") * 0.30;
    notaFinal += valor("atividades") * 0.10;
    notaFinal += valor("entrega") * 0.15;

    // Formativa
    notaFinal += valor("cognitivas") * 0.10;
    notaFinal += valor("comunicacao") * 0.10;
    notaFinal += valor("autogestao") * 0.025;
    notaFinal += valor("protagonismo") * 0.025;
    notaFinal += valor("autonomia") * 0.025;
    notaFinal += valor("interacao") * 0.025;

    document.getElementById("nota").innerHTML =
        notaFinal.toFixed(2);
}
</script>

</body>
</html>
